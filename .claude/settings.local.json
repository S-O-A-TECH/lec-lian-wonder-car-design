{
  "permissions": {
    "allow": [
      "WebFetch(domain:www.npmjs.com)",
      "WebFetch(domain:r3f.docs.pmnd.rs)",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:vitejs.dev)",
      "Bash(scripts/verify-*)",
      "Bash(npm *)",
      "Bash(cd client*)",
      "Bash(cd server*)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/verify-syntax.sh 2>/dev/null || echo 'SYNTAX CHECK: Review needed'"
          }
        ]
      }
    ]
  }
}
